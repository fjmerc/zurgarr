# Zurgarr Configuration
# =====================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only uncomment and set the values you need.
# The docker-compose.yml reads from this file automatically.
# You can also configure most settings via the web UI at /settings
# after setting STATUS_UI_AUTH below.

# --- Timezone ---
# TZ=America/New_York

# --- Zurg (debrid service) ---
ZURG_ENABLED=true
RD_API_KEY=              # Required: from https://real-debrid.com/apitoken
# AD_API_KEY=            # AllDebrid API key (alternative to RD)
# TORBOX_API_KEY=        # TorBox API key (alternative to RD)
# ZURG_VERSION=          # Pin version (e.g., v0.9.2-hotfix.4)
# ZURG_UPDATE=true       # Auto-update Zurg on startup
# ZURG_LOG_LEVEL=INFO
# ZURG_PORT=             # WebDAV port (auto-assigned if empty)
# ZURG_USER=             # WebDAV basic auth username
# ZURG_PASS=             # WebDAV basic auth password

# --- rclone (mount) ---
RCLONE_MOUNT_NAME=zurgarr
# RCLONE_LOG_LEVEL=INFO
# NFS_ENABLED=false
# NFS_PORT=
# RCLONE_CACHE_DIR=/cache
# RCLONE_DIR_CACHE_TIME=10s
# RCLONE_VFS_READ_CHUNK_SIZE=32M
# RCLONE_VFS_READ_CHUNK_SIZE_LIMIT=1G
# RCLONE_BUFFER_SIZE=32M
# RCLONE_TRANSFERS=8

# --- plex_debrid ---
# PD_ENABLED=true        # Enable plex_debrid service
# PLEX_USER=             # Plex account username
# PLEX_TOKEN=            # Plex authentication token
# PLEX_ADDRESS=          # Plex server URL (e.g., http://192.168.1.100:32400)
# SHOW_MENU=false        # Show interactive menu on startup
# PD_UPDATE=true         # Auto-update plex_debrid
# PD_LOG_LEVEL=INFO
# SEERR_API_KEY=         # Overseerr/Jellyseerr API key
# SEERR_ADDRESS=         # Overseerr/Jellyseerr URL
# TRAKT_CLIENT_ID=       # Trakt API client ID
# TRAKT_CLIENT_SECRET=   # Trakt API client secret
# FLARESOLVERR_URL=http://flaresolverr:8191/v1
# PD_ENFORCE_CACHED_VERSIONS=false   # On startup, inject a cache-required rule into every plex_debrid content version.  RECOMMENDED ON for RD users — see TROUBLESHOOTING.md "DMM shows torrents at 0% with no seeds"

# --- Jellyfin ---
# JF_ADDRESS=            # Jellyfin server URL (e.g., http://192.168.1.100:8096)
# JF_API_KEY=            # Jellyfin API key

# --- Plex Library ---
# PLEX_REFRESH=true      # Auto-refresh Plex libraries after mount changes
# PLEX_MOUNT_DIR=/zurgarr
# DUPLICATE_CLEANUP=false
# CLEANUP_INTERVAL=1     # Hours between duplicate cleanup runs
# DUPLICATE_CLEANUP_KEEP=local  # "local" (default, logs Zurg dupes) or "zurg" (deletes local copies)

# --- Notifications (Apprise) ---
# NOTIFICATION_URL=      # e.g., discord://webhook_id/webhook_token
# NOTIFICATION_EVENTS=startup,shutdown,mount_success,health_error
# NOTIFICATION_LEVEL=info

# --- Blackhole (Sonarr/Radarr integration) ---
# BLACKHOLE_ENABLED=false
# BLACKHOLE_DIR=/watch
#   BLACKHOLE_DIR supports two directory layouts (no extra env var):
#     Flat:    BLACKHOLE_DIR/<file>.torrent                  (single-arr installs)
#     Labeled: BLACKHOLE_DIR/sonarr/<file>.torrent           (each arr in its own subdir —
#              BLACKHOLE_DIR/radarr/<file>.magnet             prevents cross-arr orphan warnings)
#   Labeled symlinks are written under BLACKHOLE_COMPLETED_DIR/<label>/.
#   See BLACKHOLE_SYMLINK_GUIDE.md for the full labeled-layout setup and migration steps.
# BLACKHOLE_POLL_INTERVAL=5
# BLACKHOLE_DEBRID=realdebrid

# --- Blackhole Symlink Mode ---
# Creates symlinks in /completed pointing to debrid mount for Sonarr/Radarr import.
# Also auto-creates symlinks in local library for debrid-only content so arrs can discover it.
# See BLACKHOLE_SYMLINK_GUIDE.md for full setup instructions.
# BLACKHOLE_SYMLINK_ENABLED=false
# BLACKHOLE_RCLONE_MOUNT=/data/zurgarr       # rclone mount path inside this container
# BLACKHOLE_SYMLINK_TARGET_BASE=/mnt/debrid   # same mount as seen by Plex/Sonarr/Radarr host(s)
# BLACKHOLE_COMPLETED_DIR=/completed          # staging directory for completed symlinks
# BLACKHOLE_MOUNT_POLL_TIMEOUT=300            # seconds to wait for content on mount
# BLACKHOLE_MOUNT_POLL_INTERVAL=10            # seconds between mount polls
# BLACKHOLE_SYMLINK_MAX_AGE=72               # hours before completed symlinks are cleaned up
# SYMLINK_REPAIR_AUTO_SEARCH=false           # trigger arr re-search when broken symlinks can't be repaired
# BLACKHOLE_DEDUP_ENABLED=true               # skip torrents that match existing local library
# BLACKHOLE_LOCAL_LIBRARY_TV=                 # local TV library path (for dedup + auto-symlinks)
# BLACKHOLE_LOCAL_LIBRARY_MOVIES=             # local movie library path (for dedup + auto-symlinks)

# --- Blackhole: debrid-account dedup & cache gate ---
# Distinct from BLACKHOLE_DEDUP_ENABLED above (which compares filenames
# against a local library).  These gate the add on the debrid account
# itself — see TROUBLESHOOTING.md "DMM shows torrents at 0% with no seeds".
# BLACKHOLE_DEBRID_DEDUP_ENABLED=true        # Skip if the hash is already on the debrid account (default: ON)
# BLACKHOLE_REQUIRE_CACHED=false             # Refuse drops not confirmed cached.  RD users leave OFF (no cache probe); AD/TB can turn ON
# BLACKHOLE_DELETE_UNCACHED_ON_TIMEOUT=false  # On timeout, actively delete the uncached torrent from the debrid account.  RECOMMENDED ON for RD users — prevents 0%/0-seed junk accumulation from failed grabs

# --- Status Web UI & Settings Editor ---
STATUS_UI_ENABLED=true
# STATUS_UI_PORT=8080
STATUS_UI_AUTH=admin:changeme   # CHANGE THIS — required for settings editor

# --- Library Metadata ---
# TMDB_API_KEY=           # TMDB API key for show/movie metadata (free at themoviedb.org)

# --- Debrid Search (Library UI torrent search) ---
# TORRENTIO_URL=https://torrentio.strem.fun   # Enables interactive torrent search in the Library detail view
# SEARCH_DEDUP_ENABLED=true                    # Refuse Add clicks for hashes already on the account (default: ON)
# SEARCH_REQUIRE_CACHED=false                  # Refuse Add clicks for uncached hashes.  Same RD caveat as BLACKHOLE_REQUIRE_CACHED

# --- Media Services (for Library "Download" button) ---
# Sonarr/Radarr: Download button triggers a search in Sonarr (TV) or Radarr (Movies)
# SONARR_URL=http://sonarr:8989
# SONARR_API_KEY=
# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=
# Overseerr: Falls back to SEERR_ADDRESS/SEERR_API_KEY above if Sonarr/Radarr not configured
# ROUTING_AUTO_TAG_UNTAGGED=true         # Auto-apply debrid tag to monitored Sonarr series / Radarr movies with no routing tag during the 6h routing audit (set to 'false' to disable the self-heal)

# --- Library Preference Enforcement ---
# LIBRARY_PREFERENCE_AUTO_ENFORCE=false  # Auto-switch sources when content arrives (default: off, enable explicitly)
# DEBRID_UNAVAILABLE_THRESHOLD_DAYS=3    # Days before marking content as debrid-unavailable (default: 3)
# PENDING_WARNING_HOURS=24               # Hours before warning notification for stuck pending items (default: 24, 0 to disable)

# --- Quality Compromise & Season-Pack Fallback (plan 33) ---
# Cache-aware smart compromise for the blackhole: after the arr's alternative
# list at the preferred tier is exhausted and a configurable dwell window
# has elapsed, probe Torrentio for a cached release one tier down the arr's
# quality profile and grab it — profile is still the ceiling, Sonarr's
# normal upgrade logic still fires when the preferred tier later appears.
# Ships OFF by default (feature is additive and strictly opt-in).
# QUALITY_COMPROMISE_ENABLED=false         # Master toggle.  All other QUALITY_COMPROMISE_* / SEASON_PACK_FALLBACK_* vars are inert while this is false.
# QUALITY_COMPROMISE_DWELL_DAYS=3          # Days of failed preferred-tier attempts before the first compromise may fire (invariant I3)
# QUALITY_COMPROMISE_MIN_SEEDERS=3         # Compromise candidates below this seeder floor are skipped (availability safety net)
# QUALITY_COMPROMISE_ONLY_CACHED=true      # Refuse to compromise to an uncached release (invariant I4 — trading quality for nothing is worse than no compromise).  Real-Debrid deprecated instant-availability Nov 2024, so RD users under strict mode will never compromise; flip to `false` for aggressive escalation.
# QUALITY_COMPROMISE_MAX_TIER_DROP=2       # Cap on how far below the preferred tier the engine may descend (1 = one drop only, 2 = up to two drops; default 2).  Set to a large value (e.g. 10) to effectively disable the cap — the arr's profile ceiling remains authoritative either way.
# QUALITY_COMPROMISE_NOTIFY=true           # Send an Apprise notification on each compromise grab.  Setting to `false` silences Apprise only — the dashboard history event and pending_monitors annotation still fire (invariant I7 — observability is non-negotiable).
# SEASON_PACK_FALLBACK_ENABLED=false       # Master toggle for the TV-only season-pack strategy: probe a cached pack at the preferred tier before dropping tier, so a show with many missing episodes gets filled in without a quality compromise.
# SEASON_PACK_FALLBACK_MIN_MISSING=4       # Minimum missing-episode count in the target season before a pack probe is attempted (absolute floor)
# SEASON_PACK_FALLBACK_MIN_RATIO=0.4       # Minimum missing/total ratio for the target season (belt-and-suspenders with MIN_MISSING).  Prevents a large season with 4/40 missing (10%) from triggering a 40-episode pack grab when only a few holes exist.  0.0 disables the ratio gate.

# --- Monitoring ---
# FFPROBE_MONITOR_ENABLED=true
# FFPROBE_STUCK_TIMEOUT=300
# FFPROBE_POLL_INTERVAL=30
# AUTO_UPDATE_INTERVAL=12

# --- Logging ---
# ZURGARR_LOG_LEVEL=INFO
# ZURGARR_LOG_COUNT=2
# ZURGARR_LOG_SIZE=10M
# COLOR_LOG_ENABLED=false

# --- Advanced ---
# GITHUB_TOKEN=          # Avoid GitHub API rate limits
# SKIP_VALIDATION=false  # Skip startup config validation

# --- Backups ---
# CONFIG_BACKUP_INTERVAL=86400    # Seconds between scheduled config backups (24h). 0 disables scheduled backups (manual still works).
# CONFIG_BACKUP_RETENTION=7       # Number of scheduled backup archives to keep
# CONFIG_BACKUP_DIR=/config/backups
